{
  "manifest_version": 3,
  "name": "Playlist Info Exporter",
  "description": "Export Spotify playlists with ISRC, language detection, and Google AI Mode support.",
  "version": "2.1.5",
  "permissions": [
    "activeTab",
    "alarms",
    "debugger",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.google.com/*",
    "https://open.spotify.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Playlist Info Exporter"
  },
  "content_scripts": [
    {
      "matches": [
        "https://playlistinfoexporter.vercel.app/*",
        "https://playlistinfoexporter.onrender.com/*",
        "https://playlistinfoexporter.netlify.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "page-connector.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.google.com/search*",
        "*://google.com/search*"
      ],
      "js": [
        "google-followup.js"
      ],
      "run_at": "document_idle"
    }
  ]
}